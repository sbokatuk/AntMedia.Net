<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>com.sbokatuk.antmedia.devicetests</string>
	<key>CFBundleName</key>
	<string>AntMediaDeviceTests</string>
	<key>CFBundleDisplayName</key>
	<string>AntMedia.Net device tests</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>MinimumOSVersion</key>
	<string>13.0</string>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!--
	  The SDK opens the camera and microphone in real use. The smoke test never does, but the
	  usage descriptions are declared anyway: without them a call that does would terminate the
	  app rather than fail, which would be a confusing way to discover the omission.
	-->
	<key>NSCameraUsageDescription</key>
	<string>Required by the Ant Media WebRTC SDK to publish video.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Required by the Ant Media WebRTC SDK to publish audio.</string>
</dict>
</plist>
