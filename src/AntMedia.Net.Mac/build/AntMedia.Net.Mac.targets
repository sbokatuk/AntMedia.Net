<?xml version="1.0" encoding="utf-8"?>
<!--
  Imported automatically by any project that references the AntMedia.Net.Mac package (NuGet
  imports build/<package-id>.targets). The iOS package carries the same file for the same reason:
  both xcframeworks are dynamic, so they cannot be embedded in the binding assembly and have to be
  declared as NativeReference in the consuming project, where the linker and the app bundler can
  both see them. See build/AntMedia.Net.iOS.targets for the full explanation.
-->
<Project>

  <ItemGroup Condition=" '$(TargetPlatformIdentifier)' == 'maccatalyst' ">
    <NativeReference Include="$(MSBuildThisFileDirectory)../native/WebRTCiOSSDK.xcframework">
      <Kind>Framework</Kind>
      <Visible>false</Visible>
    </NativeReference>

    <NativeReference Include="$(MSBuildThisFileDirectory)../native/WebRTC.xcframework">
      <Kind>Framework</Kind>
      <Frameworks>AVFoundation AudioToolbox CoreAudio CoreMedia CoreVideo CoreGraphics VideoToolbox Metal MetalKit</Frameworks>
      <Visible>false</Visible>
    </NativeReference>
  </ItemGroup>

  <!--
    Apple Silicon only, and worth saying up front: the WebRTCiOSSDK slice is arm64, because Ant
    Media's renderer falls back to OpenGL when arch != arm64 and Mac Catalyst has no OpenGL. An
    x86_64 Catalyst build therefore fails at link time with undefined RTCEAGLVideoView symbols,
    which says nothing about the cause.
  -->
  <Target Name="AntMediaMacCatalystArchitectureCheck"
          BeforeTargets="Build"
          Condition=" '$(TargetPlatformIdentifier)' == 'maccatalyst' AND '$(RuntimeIdentifier)' == 'maccatalyst-x64' ">
    <Error Text="AntMedia.Net.Mac supports Apple Silicon only (maccatalyst-arm64). The Ant Media SDK uses OpenGL for rendering on non-arm64 architectures, and Mac Catalyst has no OpenGL, so no x86_64 slice can be built. Set &lt;RuntimeIdentifiers&gt;maccatalyst-arm64&lt;/RuntimeIdentifiers&gt;." />
  </Target>

</Project>
