<?xml version="1.0" encoding="utf-8"?>
<!--
  Imported automatically by any project that references the AntMedia.Net.iOS package (NuGet
  imports build/<package-id>.targets).

  Why the package needs this:
  Both xcframeworks are *dynamic*. A dynamic framework cannot be embedded into a binding assembly
  and linked from there: the app's linker never sees it, and the build fails with

      Undefined symbols for architecture arm64:
        "_OBJC_CLASS_$_AMSClient", referenced from: <initial-undefines>

  because the registrar passes -u for every bound Objective-C class while nothing supplies them.
  So the frameworks ship as package content and are declared as NativeReference here, in the
  consuming project, where the linker and the app bundler can both see them.
-->
<Project>

  <ItemGroup Condition=" '$(TargetPlatformIdentifier)' == 'ios' ">
    <NativeReference Include="$(MSBuildThisFileDirectory)../native/WebRTCiOSSDK.xcframework">
      <Kind>Framework</Kind>
      <Visible>false</Visible>
    </NativeReference>

    <!--
      Ant Media's build of libwebrtc. The Frameworks list is what it dlopens; omitting them leaves
      the app to fail at launch rather than at link time.
    -->
    <NativeReference Include="$(MSBuildThisFileDirectory)../native/WebRTC.xcframework">
      <Kind>Framework</Kind>
      <Frameworks>AVFoundation AudioToolbox CoreAudio CoreMedia CoreVideo CoreGraphics VideoToolbox Metal MetalKit</Frameworks>
      <Visible>false</Visible>
    </NativeReference>
  </ItemGroup>

</Project>
