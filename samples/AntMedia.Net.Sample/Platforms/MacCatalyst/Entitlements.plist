<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required for a sandboxed Mac Catalyst app to reach the network at all. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Publishing captures from the camera and microphone. Unlike iOS, a sandboxed Catalyst app
	     needs these entitlements as well as the Info.plist usage descriptions: without them the
	     capture device simply never delivers frames, with no permission prompt and no error. -->
	<key>com.apple.security.device.camera</key>
	<true/>
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
