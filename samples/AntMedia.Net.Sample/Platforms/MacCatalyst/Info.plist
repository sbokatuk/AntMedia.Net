<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIDeviceFamily</key>
	<array>
		<integer>2</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>

	<!-- Publishing captures from the camera and microphone; macOS terminates the app if it opens
	     either without a usage description. The entitlements beside this file are needed too. -->
	<key>NSCameraUsageDescription</key>
	<string>Used to publish your video to the Ant Media Server.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Used to publish your audio to the Ant Media Server.</string>
</dict>
</plist>
