<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Locally packed AntMedia.Net packages. The device tests and the sample app reference the
      packed .nupkg rather than the binding projects, so the e2e runs against exactly what gets
      published.
    -->
    <add key="local-artifacts" value="artifacts" />
  </packageSources>

  <!--
    AntMedia.* only ever resolves from artifacts/: without the mapping, a version that also
    exists on nuget.org (or lingers in the global package cache) would be restored silently in
    place of the freshly packed one, and the sample and device tests would be testing the
    published release while appearing to test the working tree.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="local-artifacts">
      <package pattern="AntMedia.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
